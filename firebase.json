{
  "hosting": {
    "target": "main_site",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/comp/**",
        "function": { "functionId": "ogMeta", "region": "us-central1" }
      },
      {
        "source": "/admin/**",
        "function": { "functionId": "ogMeta", "region": "us-central1" }
      },
      {
        "source": "/vote/**",
        "function": { "functionId": "ogMeta", "region": "us-central1" }
      },
      {
        "source": "/login/**",
        "function": { "functionId": "ogMeta", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix functions install --prefer-offline"
      ]
    }
  ]
}
